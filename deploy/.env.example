# =============================================================
# Warp9Net IPAM — Environment Variables
# Copy this to .env and fill in your values
# =============================================================

# ── Postgres ─────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-postgres-password

# ── JWT (generate with: openssl rand -base64 32) ─────────────
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# ── Supabase Keys ────────────────────────────────────────────
# Generate these using your JWT_SECRET at:
# https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# ── URLs ─────────────────────────────────────────────────────
# The public URL where your Supabase API will be accessible
# This goes through your Kong gateway on port 8000
API_EXTERNAL_URL=http://ipam.warp9studios.com:8000

# The frontend URL (used by GoTrue for redirects)
SITE_URL=https://ipam.warp9studios.com

# ── Realtime ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
SECRET_KEY_BASE=your-secret-key-base-at-least-64-chars

# ── SMTP (for email verification) ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@warp9studios.com

# ── Build Args (used in Dockerfile) ──────────────────────────
# Point these to your self-hosted Supabase Kong gateway
VITE_SUPABASE_URL=http://ipam.warp9studios.com:8000
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
